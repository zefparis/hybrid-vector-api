# deepface-api configuration
DEEPFACE_API_URL=https://deepface-api-mid3.onrender.com
DEEPFACE_API_KEY=your_deepface_api_key_here

# HCS-U7 configuration
HCS_API_URL=https://hcs-u7.onrender.com
HCS_API_KEY=your_hcs_api_key_here

# Supabase configuration (EDGUARD)
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_KEY=service_role_key_here

# hv-api configuration
HV_API_KEY=your_hv_api_key_here

# JWT configuration
JWT_SECRET=your_jwt_secret_min_32_characters_here
JWT_EXPIRES_IN=3600

# HCS-U7 ingest (fire-and-forget session push)
HCS_INGEST_URL=https://api.hcs-u7.org/api/hybrid-vector/session/ingest
HCS_WORKER_SHARED_SECRET=your_hcs_worker_shared_secret_here

# CORS — comma-separated additional allowed origins (*.vercel.app is always allowed)
ALLOWED_ORIGINS=https://your-custom-domain.com

# Server configuration
PORT=3000
NODE_ENV=production
